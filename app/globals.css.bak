@tailwind base;
@tailwind components;
@tailwind utilities;

html, body {
  background-color: #F5F0E8 !important;
  color: #3D2C29 !important;
}

@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Outfit:wght@300;400;500;600&display=swap');

@media print {
  @page {
    size: A4;
    margin: 5mm;
  }
  * {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
  }
  *::-webkit-scrollbar {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
  }
  .no-print {
    display: none !important;
  }
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    background: white !important;
    overflow: hidden !important;
    width: 210mm !important;
    height: 297mm !important;
  }
  .min-h-screen {
    margin: 0 !important;
    padding: 0 !important;
    min-height: 297mm !important;
    max-height: 297mm !important;
    width: 210mm !important;
    overflow: hidden !important;
    display: flex !important;
    justify-content: center !important;
    align-items: flex-start !important;
  }
  /* A4 natif : pas de scale, la colonne droite emplit la largeur */
  #cv-content {
    padding: 0 !important;
    width: 200mm !important;
    max-width: 200mm !important;
    transform: none !important;
    flex-shrink: 0 !important;
  }
  #cv-card {
    flex-direction: row !important;
    page-break-inside: avoid !important;
    break-inside: avoid !important;
    width: 200mm !important;
    min-height: 287mm !important;
    overflow: hidden !important;
    border: 2px solid #8B7B6F !important;
    border-top: 2px solid #8B7B6F !important;
    box-sizing: border-box !important;
  }
  /* Colonne gauche = étroite - blocs jusqu'au bord haut */
  #cv-sidebar {
    width: 55mm !important;
    min-width: 55mm !important;
    max-width: 55mm !important;
    flex: 0 0 55mm !important;
    order: 1 !important;
    align-self: stretch !important;
    padding: 0 !important;
    text-align: center !important;
  }
  #cv-sidebar > div:first-child {
    padding-top: 0.25rem !important;
  }
  #cv-sidebar h1,
  #cv-sidebar h2,
  #cv-sidebar p,
  #cv-sidebar a {
    text-align: center !important;
  }
  /* Colonne droite = large - blocs jusqu'au bord haut */
  #cv-card main {
    flex: 1 1 auto !important;
    min-width: 0 !important;
    order: 2 !important;
    padding: 0 0 1.25rem 0 !important;
  }
#body-profile {
  margin-top: 2.5rem !important;
}
  #cv-card main #section-header {
    display: none !important;
  }
  #main-sections {
    overflow: visible !important;
    width: 100% !important;
  }
  #body-experience,
  #experiences-container {
    width: 100% !important;
    max-width: 100% !important;
  }
  .section-body {
    overflow: visible !important;
    max-height: none !important;
  }
  #cv-card main p,
  #cv-card main .leading-relaxed {
    line-height: 1.5 !important;
  }
  #body-profile p {
    font-size: 16px !important;
  }
  #section-experience h2 {
    font-size: 1.5rem !important;
  }
  #body-experience h3 {
    font-size: 1.25rem !important;
  }
  #body-experience p {
    font-size: 14px !important;
  }
  #experiences-container > div {
    margin-top: 1.25em !important;
  }
  #experiences-container > div:first-child {
    margin-top: 0 !important;
  }
  .card-hover:hover {
    transform: none !important;
  }
}

.card-hover:hover {
  transform: translateY(-2px);
}

.export-pdf .no-print {
  display: none !important;
}
.export-pdf .hide-in-preview-export {
  display: none !important;
}
body.export-pdf,
html.export-pdf {
  overflow: hidden !important;
  scrollbar-width: none !important;
  -ms-overflow-style: none !important;
  background: white !important;
}
body.export-pdf ::-webkit-scrollbar,
html.export-pdf ::-webkit-scrollbar {
  display: none !important;
}
.export-pdf .min-h-screen,
.export-pdf #cv-content {
  background: white !important;
  overflow: hidden !important;
}
.export-pdf * {
  scrollbar-width: none !important;
  -ms-overflow-style: none !important;
}
.export-pdf *::-webkit-scrollbar {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
}
.export-pdf #cv-card {
  display: flex !important;
  flex-direction: row !important;
  border: 2px solid #8B7B6F !important;
  box-shadow: none !important;
}
.export-pdf #cv-content {
  border: none !important;
  box-shadow: none !important;
}
.export-pdf #cv-sidebar {
  border-right: 2px solid #8B7B6F !important;
  box-shadow: none !important;
}

.preview-mode .no-print {
  display: none !important;
}
body.preview-mode #cv-content {
  display: none !important;
}

#preview-iframe {
  position: fixed;
  top: 3.5rem;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: calc(100vh - 3.5rem);
  border: none;
  background: #f5f0e8;
}
#preview-iframe.hidden {
  display: none !important;
}

.preview-banner {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(61, 44, 41, 0.95);
  color: #f5f0e8;
  padding: 0.75rem 1.5rem;
  text-align: center;
  font-size: 0.875rem;
  z-index: 40;
}
.preview-banner .preview-close {
  background: transparent;
  border: 1px solid rgba(245, 240, 232, 0.5);
  color: #f5f0e8;
  padding: 0.35rem 1rem;
  border-radius: 0.5rem;
  cursor: pointer;
  margin-left: 1rem;
}
.preview-banner .preview-close:hover {
  background: rgba(255, 255, 255, 0.2);
}

.section-body {
  overflow-y: auto;
  min-height: 60px;
}

#body-skills {
  overflow: visible !important;
  max-height: none !important;
  min-height: fit-content !important;
}
#body-skills span {
  white-space: pre-line !important;
}
#body-experience {
  overflow: visible !important;
  max-height: none !important;
}

/* Expériences : espace au-dessus du bloc titre */
#section-experience {
  padding-top: 2rem !important;
}
#section-experience > div:first-child {
  padding-top: 2.5rem !important;
}
#section-experience > div:first-child h2 {
  padding-top: 0 !important;
}

#section-profile #body-profile,
#section-profile .section-body {
  background: transparent !important;
}

/* Expériences : espace au-dessus du bloc titre */
#section-experience {
  padding-top: 2rem !important;
}
#section-experience > div:first-child {
  padding-top: 2.5rem !important;
}
#section-experience > div:first-child h2 {
  padding-top: 0 !important;
}

/* Profil : descendre le texte d'une ligne */
#body-profile {
  margin-top: 2rem !important;
}

/* Bloc Profil : espace au-dessus du texte (descendre d'une ligne) */
#body-profile {
  margin-top: 2rem !important;
}

/* Bloc Profil : descendre le texte d'une ligne */
#body-profile {
  margin-top: 2.5rem !important;
}

/* Bloc Profil : descendre le texte d'une ligne */
#body-profile {
  margin-top: 2.5rem !important;
}

/* Bloc Profil : descendre le texte d'une ligne */
#body-profile {
  margin-top: 2.5rem !important;
}

/* Bloc Poste recherché supprimé du CV */
#body-profile {
  margin-top: 2.5rem !important;
}
#section-header {
  display: none !important;
}

/* Enfants du bloc Profil : fond transparent pour laisser voir la couleur du parent */
#section-profile #body-profile,
#section-profile .section-body {
  background: transparent !important;
}

#cv-content {
  border: none !important;
  box-shadow: none !important;
  filter: none !important;
}
#cv-card {
  width: 900px;
  max-width: 100%;
  min-height: 297mm;
  border: 2px solid #8B7B6F;
  box-shadow: none !important;
  filter: none !important;
}
#cv-sidebar {
  border-right: 2px solid #8B7B6F !important;
  box-shadow: none !important;
}
#cv-sidebar h1 {
  font-size: calc(1.25rem + 1pt) !important;
}
#cv-sidebar h2 {
  text-align: center !important;
}
#body-contact .space-y-3,
#body-formation,
#body-interests {
  text-align: center !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
}
#body-skills {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  text-align: center !important;
}
#body-skills > .flex {
  justify-content: center !important;
}
#body-contact > div:first-child .flex {
  justify-content: center !important;
}
#body-contact > h2 {
  text-align: center !important;
}
